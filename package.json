{
  "name": "immersive-clock",
  "private": true,
  "description": "一款支持时钟、倒计时、秒表与自习模式的轻量时钟应用。",
  "version": "3.13.3",
  "author": "QQHKX <contact@qqhkx.com>",
  "homepage": "https://qqhkx.com",
  "license": "GPL-3.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "engines": {
    "node": ">=20.19.0"
  },
  "overrides": {
    "serialize-javascript": "7.0.5"
  },
  "scripts": {
    "dev": "vite",
    "dev:electron": "vite --mode electron",
    "build": "vite build && node scripts/postbuild.mjs",
    "build:electron": "node --input-type=module -e \"import fs from 'fs'; fs.rmSync('dist-electron',{ recursive:true, force:true });\" && vite build --mode electron && node scripts/postbuild-electron.mjs",
    "dist:electron": "cnpm run build:electron && cnpm run pack:electron",
    "pack:electron": "electron-builder",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,css,md,json}\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e:install": "playwright install",
    "pretest:e2e": "node scripts/ensure-playwright.mjs",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@microsoft/clarity": "^1.0.2",
    "driver.js": "^1.4.0",
    "marked": "^18.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-feather": "^2.0.10",
    "react-router-dom": "^7.14.2",
    "read-excel-file": "^9.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-react": "^5.2.0",
    "baseline-browser-mapping": "^2.10.24",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "jsdom": "^29.1.0",
    "prettier": "^3.8.3",
    "terser": "^5.46.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^7.3.2",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-pwa": "^1.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "vitest": "^4.1.5",
    "workbox-window": "^7.4.0",
    "@playwright/test": "^1.59.1"
  }
}
