# Immersive Clock — 环境变量配置

# [必填] Neon PostgreSQL 连接字符串（多设备同步功能必需）
# 在 neon.tech 创建项目后，从 Connection Details 复制
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# [可选] Admin 登录密码，留空则不校验（仅内网部署时可不填）
# 只需要配置这一个变量即可。登录校验完全在服务端完成（/api/login），
# 前端代码中不会出现明文密码，登录后只保存一个有时效的签名 token。
# ADMIN_SECRET=your_secret_here

# [已废弃、请勿再使用] 旧版本需要同时配置 VITE_ADMIN_SECRET，
# 但它会被 Vite 打包进发给浏览器的 JS 代码里，任何访客打开开发者工具都能直接看到密码明文。
# 升级后请删除这个变量。
# VITE_ADMIN_SECRET=

# [可选] 高德地图 Web API Key
# 用于逆向地理编码（获取城市名）。不填时自动降级使用 OpenStreetMap
# VITE_AMAP_API_KEY=

# [已废弃] 以下配置已迁移到 Open-Meteo，无需填写
# VITE_XIAOMI_WEATHER_API_HOST=
# VITE_XIAOMI_WEATHER_PROXY_PREFIX=